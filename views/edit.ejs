<%- include('partials/header') %>

<div class="form-page">
  <div class="container--narrow">

    <div class="form-header">
      <p class="form-header__eyebrow">Editing</p>
      <h1 class="form-header__title"><%= post.title %></h1>
    </div>

    <form class="post-form" action="/posts/<%= post.id %>/update" method="POST">

      <div class="form-group">
        <label for="title">Title</label>
        <input
          type="text"
          id="title"
          name="title"
          class="form-control"
          value="<%= post.title %>"
          required
          autocomplete="off"
        />
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="author">Author</label>
          <input
            type="text"
            id="author"
            name="author"
            class="form-control"
            value="<%= post.author %>"
            autocomplete="off"
          />
        </div>
        <div class="form-group">
          <label for="category">Category</label>
          <input
            type="text"
            id="category"
            name="category"
            class="form-control"
            value="<%= post.category %>"
            autocomplete="off"
          />
        </div>
      </div>

      <div class="form-group">
        <label for="excerpt">Excerpt <span class="label-opt">(optional)</span></label>
        <input
          type="text"
          id="excerpt"
          name="excerpt"
          class="form-control"
          value="<%= post.excerpt %>"
          autocomplete="off"
        />
        <span class="form-hint">Appears on the homepage card.</span>
      </div>

      <div class="form-group">
        <label for="content">Content</label>
        <textarea
          id="content"
          name="content"
          class="form-control"
          required
        ><%= post.content %></textarea>
        <span class="form-hint">Separate paragraphs with a blank line.</span>
      </div>

      <div class="form-footer">
        <a href="/posts/<%= post.id %>" class="btn btn--ghost">Cancel</a>
        <button type="submit" class="btn btn--primary btn--lg">
          <svg width="13" height="13" viewBox="0 0 13 13" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M10.5 1.5l1 1L4 10H2.5V8.5L10.5 1.5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
          </svg>
          Save Changes
        </button>
      </div>

    </form>
  </div>
</div>

<%- include('partials/footer') %>
